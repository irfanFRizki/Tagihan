#!/usr/bin/env python3
import json, os, sys, time, subprocess, urllib.request, urllib.parse, urllib.error, ssl

CACHE_DIR = "/tmp/tagihan"
os.makedirs(CACHE_DIR, exist_ok=True)

ssl_ctx = ssl.create_default_context()
ssl_ctx.check_hostname = False
ssl_ctx.verify_mode = ssl.CERT_NONE

def uci_get(key, default=""):
    try:
        r = subprocess.run(["uci", "-q", "get", key], capture_output=True, text=True, timeout=5)
        return r.stdout.strip() if r.returncode == 0 else default
    except Exception:
        return default

def uci_set(key, value):
    try:
        subprocess.run(["uci", "-q", "set", f"{key}={value}"], capture_output=True, timeout=5)
    except Exception:
        pass

def uci_commit(config="tagihan"):
    try:
        subprocess.run(["uci", "-q", "commit", config], capture_output=True, timeout=5)
    except Exception:
        pass

def save_cache(name, data):
    try:
        with open(f"{CACHE_DIR}/{name}.json", "w") as f:
            json.dump(data, f)
    except Exception:
        pass

def http_get(url, headers=None):
    h = {"User-Agent": "Mozilla/5.0", "Accept": "application/json"}
    if headers:
        h.update(headers)
    req = urllib.request.Request(url, headers=h)
    with urllib.request.urlopen(req, timeout=20, context=ssl_ctx) as r:
        return r.read().decode("utf-8", errors="ignore")

def http_post(url, data, headers=None):
    h = {"User-Agent": "Mozilla/5.0", "Content-Type": "application/json", "Accept": "application/json"}
    if headers:
        h.update(headers)
    body = json.dumps(data).encode() if isinstance(data, dict) else data
    req = urllib.request.Request(url, data=body, headers=h, method="POST")
    with urllib.request.urlopen(req, timeout=20, context=ssl_ctx) as r:
        return r.read().decode("utf-8", errors="ignore")

def check_pln():
    if uci_get("tagihan.pln.enabled") != "1":
        return {"status": "disabled"}
    idpel = uci_get("tagihan.pln.idpel")
    if not idpel:
        return {"status": "error", "message": "ID Pelanggan belum diisi"}
    print(f"[PLN] Cek ID: {idpel}")
    for url in [f"https://api.pln.co.id/token/v2/registrations/{idpel}",
                f"https://api.pln.co.id/token/v1/registrations/{idpel}"]:
        try:
            raw = http_get(url, {"Authorization": "Basic cGxuOnBsbg=="})
            d = json.loads(raw)
            r = d.get("data", d.get("response", {}).get("results", d))
            if isinstance(r, dict) and (r.get("nama") or r.get("responseCode") == "00"):
                res = {"status": "ok", "nama": r.get("nama",""), "idpel": idpel,
                       "tarif": r.get("tarif",""), "daya": r.get("daya",""),
                       "tagihan": r.get("totalTagihan", r.get("jumlahTagihan", 0)),
                       "periode": "", "last_update": int(time.time())}
                det = r.get("detilTagihan", [])
                if isinstance(det, list) and det:
                    res["periode"] = det[0].get("periode", "")
                    if not res["tagihan"]:
                        res["tagihan"] = det[0].get("total", 0)
                print(f"[PLN] OK - {res['nama']}")
                return res
        except Exception as e:
            print(f"[PLN] {url}: {e}")
    return {"status": "error", "message": "Gagal ambil data PLN", "last_update": int(time.time())}

def check_pdam():
    if uci_get("tagihan.pdam.enabled") != "1":
        return {"status": "disabled"}
    nomor = uci_get("tagihan.pdam.nomor_pelanggan")
    if not nomor:
        return {"status": "error", "message": "Nomor pelanggan belum diisi"}
    print(f"[PDAM] Cek nomor: {nomor}")
    for url in ["https://pelanggan.pamjaya.co.id/api/tagihan",
                "https://pelanggan.pamjaya.co.id/api/cek-tagihan"]:
        try:
            raw = http_post(url, {"nomorPelanggan": nomor, "noCustomer": nomor})
            d = json.loads(raw)
            r = d.get("data", d.get("result", d))
            if isinstance(r, dict):
                tagihan = r.get("totalTagihan", r.get("total", 0))
                nama = r.get("nama", "")
                if tagihan or nama:
                    res = {"status": "ok", "nama": nama, "nomor": nomor,
                           "tagihan": tagihan, "periode": r.get("periode",""),
                           "pemakaian": r.get("pemakaian",""), "last_update": int(time.time())}
                    print(f"[PDAM] OK - {nama}")
                    return res
        except Exception as e:
            print(f"[PDAM] {url}: {e}")
    return {"status": "error", "message": "Gagal ambil data PDAM", "last_update": int(time.time())}

def check_wifi():
    if uci_get("tagihan.wifi.enabled") != "1":
        return {"status": "disabled"}
    email = uci_get("tagihan.wifi.email")
    password = uci_get("tagihan.wifi.password")
    if not email or not password:
        return {"status": "error", "message": "Email/password belum diisi"}
    print(f"[WiFi] Login: {email}")
    import http.cookiejar, re
    jar = http.cookiejar.CookieJar()
    opener = urllib.request.build_opener(
        urllib.request.HTTPCookieProcessor(jar),
        urllib.request.HTTPSHandler(context=ssl_ctx))
    for login_url in ["https://member.myrepublic.net.id/customer/login",
                      "https://myrepublic.net.id/my-account"]:
        try:
            req = urllib.request.Request(login_url, headers={"User-Agent": "Mozilla/5.0"})
            page = opener.open(req, timeout=15).read().decode("utf-8", errors="ignore")
            nonce = ""
            m = re.search(r'name="[_]nonce"\s+value="([^"]+)"', page)
            if m:
                nonce = m.group(1)
            payload = {"log": email, "pwd": password, "username": email,
                       "password": password, "login": "Login"}
            if nonce:
                payload["_wpnonce"] = nonce
            form_data = urllib.parse.urlencode(payload).encode()
            req2 = urllib.request.Request(login_url, data=form_data, headers={
                "Content-Type": "application/x-www-form-urlencoded",
                "User-Agent": "Mozilla/5.0", "Referer": login_url})
            resp2 = opener.open(req2, timeout=15)
            content = resp2.read().decode("utf-8", errors="ignore")
            if "logout" in content.lower() or "invoice" in content.lower():
                for bill_url in ["https://myrepublic.net.id/my-account/orders/",
                                  "https://myrepublic.net.id/my-account/"]:
                    try:
                        req3 = urllib.request.Request(bill_url, headers={"User-Agent": "Mozilla/5.0"})
                        html = opener.open(req3, timeout=15).read().decode("utf-8", errors="ignore")
                        tagihan = 0
                        for pat in [r'(?:Rp|IDR)[.\s]*(\d[\d,.]+)', r'"amount"\s*:\s*"?(\d+)"?']:
                            m2 = re.search(pat, html, re.IGNORECASE)
                            if m2:
                                raw_n = m2.group(1).replace(".", "").replace(",", "")
                                if raw_n.isdigit() and int(raw_n) > 10000:
                                    tagihan = int(raw_n)
                                    break
                        jatuh_tempo = ""
                        m3 = re.search(r'(?:Due Date|Jatuh Tempo)[^:]*:\s*([0-9A-Za-z ,/-]+)', html, re.IGNORECASE)
                        if m3:
                            jatuh_tempo = m3.group(1).strip()[:30]
                        if tagihan > 0:
                            return {"status": "ok", "email": email, "nama_paket": "MyRepublic",
                                    "tagihan": tagihan, "jatuh_tempo": jatuh_tempo,
                                    "last_update": int(time.time())}
                    except Exception as e:
                        print(f"[WiFi] billing {bill_url}: {e}")
        except Exception as e:
            print(f"[WiFi] login {login_url}: {e}")
    return {"status": "error", "message": "Gagal login MyRepublic", "last_update": int(time.time())}

def save_to_uci(service, result):
    status = result.get("status", "error")
    uci_set(f"tagihan.{service}.status", status)
    uci_set(f"tagihan.{service}.last_update", str(result.get("last_update", int(time.time()))))
    if service == "pln" and status == "ok":
        uci_set("tagihan.pln.nama",    result.get("nama",""))
        uci_set("tagihan.pln.tagihan", str(result.get("tagihan",0)))
        uci_set("tagihan.pln.periode", result.get("periode",""))
        uci_set("tagihan.pln.daya",    result.get("daya",""))
        uci_set("tagihan.pln.tarif",   result.get("tarif",""))
    elif service == "pdam" and status == "ok":
        uci_set("tagihan.pdam.nama",      result.get("nama",""))
        uci_set("tagihan.pdam.tagihan",   str(result.get("tagihan",0)))
        uci_set("tagihan.pdam.periode",   result.get("periode",""))
        uci_set("tagihan.pdam.pemakaian", str(result.get("pemakaian","")))
    elif service == "wifi" and status == "ok":
        uci_set("tagihan.wifi.nama_paket",  result.get("nama_paket",""))
        uci_set("tagihan.wifi.tagihan",     str(result.get("tagihan",0)))
        uci_set("tagihan.wifi.jatuh_tempo", result.get("jatuh_tempo",""))
    uci_commit("tagihan")
    save_cache(service, result)

if __name__ == "__main__":
    target = sys.argv[1] if len(sys.argv) > 1 else "all"
    print(f"=== Tagihan Check: {target} ===")
    if target in ("pln", "all"):
        r = check_pln(); save_to_uci("pln", r); print(f"[PLN] {r['status']}")
    if target in ("pdam", "all"):
        r = check_pdam(); save_to_uci("pdam", r); print(f"[PDAM] {r['status']}")
    if target in ("wifi", "all"):
        r = check_wifi(); save_to_uci("wifi", r); print(f"[WiFi] {r['status']}")
    print("=== Selesai ===")
