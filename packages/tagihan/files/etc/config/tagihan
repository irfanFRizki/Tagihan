# /etc/config/tagihan
# Konfigurasi Tagihan Bot - irfanFRizki

config tagihan 'pdam'
    option enabled '0'
    option nomor_pelanggan ''
    option nama ''
    option tagihan '0'
    option periode ''
    option pemakaian ''
    option bayar_status ''
    option golongan ''
    option jatuh_tempo ''
    option status 'belum_dicek'
    option last_update ''
    option last_check_time ''

config tagihan 'wifi'
    option enabled '0'
    option email ''
    option app_password ''
    option nama ''
    option id_pelanggan ''
    option tagihan '0'
    option tagihan_str ''
    option invoice ''
    option jatuh_tempo ''
    option status_bayar ''
    option status 'belum_dicek'
    option last_update ''
    option last_check_time ''

config tagihan 'telegram'
    option enabled '0'
    option bot_token ''
    option chat_id ''
    option notify_on_check '1'
    option schedule_enabled '0'
    option schedule_type 'daily'
    option schedule_hour '8'
    option schedule_minute '0'
    option schedule_day '1'

config tagihan 'settings'
    option auto_check '1'
    option interval '6'
